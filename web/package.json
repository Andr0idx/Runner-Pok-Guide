{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "desktop:dev": "\"%npm_node_execpath%\" \"./node_modules/electron/cli.js\" .",
    "desktop:bridge": "python ../realtime_bridge.py",
    "desktop:portable": "electron-builder --win portable",
    "desktop:pack": "electron-builder --dir",
    "desktop:dist": "electron-builder"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "electron": "^36.3.2",
    "electron-builder": "^25.1.8",
    "globals": "^17.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.10"
  },
  "build": {
    "appId": "com.pokeguide.desktop",
    "productName": "PokéGuide",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "electron/**"
    ],
    "extraResources": [
      {
        "from": "../index.html",
        "to": "app/index.html"
      },
      {
        "from": "../manifest.webmanifest",
        "to": "app/manifest.webmanifest"
      },
      {
        "from": "../pokeball.svg",
        "to": "app/pokeball.svg"
      },
      {
        "from": "../sw.js",
        "to": "app/sw.js"
      },
      {
        "from": "../realtime_bridge.py",
        "to": "bridge/realtime_bridge.py"
      }
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "perMachine": false,
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
